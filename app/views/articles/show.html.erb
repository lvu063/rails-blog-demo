<div class="article-show">
  <div class="article-meta" style="margin-bottom: 0.75rem;">
    <span class="category-badge"><%= @article.category %></span>
    <span><%= @article.created_at.strftime("%B %d, %Y") %></span>
  </div>

  <h1><%= @article.title %></h1>
  <div class="article-body"><%= @article.body %></div>

  <div class="article-actions">
    <%= link_to "Edit", edit_article_path(@article), class: "btn btn-secondary" %>
    <%= button_to "Delete", article_path(@article), method: :delete,
        class: "btn btn-danger btn-sm",
        data: { turbo_confirm: "Delete this article?" } %>
    <%= link_to "← All Articles", articles_path, class: "btn btn-secondary" %>
  </div>
</div>

<div class="comments-section">
  <h2><%= pluralize(@article.comments.count, "Comment") %></h2>

  <% @article.comments.each do |comment| %>
    <div class="comment">
      <div class="comment-author"><%= comment.commenter %></div>
      <div class="comment-body"><%= comment.body %></div>
      <div class="comment-footer">
        <%= button_to "Delete", article_comment_path(@article, comment),
            method: :delete, class: "btn btn-secondary btn-sm",
            data: { turbo_confirm: "Delete this comment?" } %>
      </div>
    </div>
  <% end %>

  <div class="form-card" style="margin-top: 1.5rem;">
    <h3 style="font-size: 1rem; font-weight: 600; color: var(--navy); margin-bottom: 1rem;">Add a Comment</h3>
    <%= form_with model: [@article, @comment] do |form| %>
      <div class="form-group">
        <%= form.label :commenter, "Your name" %>
        <%= form.text_field :commenter, placeholder: "Your name" %>
      </div>
      <div class="form-group">
        <%= form.label :body, "Comment" %>
        <%= form.text_area :body, placeholder: "Write a comment..." %>
      </div>
      <div class="form-actions">
        <%= form.submit "Post Comment", class: "btn btn-primary" %>
      </div>
    <% end %>
  </div>
</div>
