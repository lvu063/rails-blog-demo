<div class="page-header">
  <h1>Articles</h1>
  <%= link_to "New Article", new_article_path, class: "btn btn-primary" %>
</div>

<div class="category-bar">
  <%= link_to "All", articles_path, class: "category-pill #{params[:category].blank? ? 'active' : ''}" %>
  <% Article::CATEGORIES.each do |cat| %>
    <%= link_to cat, articles_path(category: cat), class: "category-pill #{params[:category] == cat ? 'active' : ''}" %>
  <% end %>
</div>

<% if @articles.any? %>
  <div class="articles-grid">
    <% @articles.each do |article| %>
      <%= link_to article_path(article), class: "article-card" do %>
        <h2><%= article.title %></h2>
        <div class="article-meta">
          <span class="category-badge"><%= article.category %></span>
          <span><%= article.created_at.strftime("%b %d, %Y") %></span>
          <span><%= pluralize(article.comments.count, "comment") %></span>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <div class="empty-state">
    <h3>No articles yet</h3>
    <p>Be the first to <%= link_to "write one", new_article_path %>.</p>
  </div>
<% end %>
